{
  "compilerOptions": {
    "allowJs": false,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": false,
    "target": "ES2022",
    "useUnknownInCatchVariables": false
  },
  "include": [
    "internal/web/static/**/*.ts",
    "internal/web/static/**/*.d.ts"
  ]
}
